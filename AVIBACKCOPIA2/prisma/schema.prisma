// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ADMIN {
  idADMIN  Int     @id
  nombre   String
  email    String  @unique
  activo   Boolean @default(true)
  password String
  foto     String?
}

model CENTRO {
  idCENTRO    Int    @id @default(autoincrement())
  descripcion String @db.VarChar(500)

  ambientes AMBIENTE[]
  programas PROGRAMA[]
}

model AMBIENTE {
  idAMBIENTE      Int    @id @default(autoincrement())
  descripcion     String @db.VarChar(500)
  caracteristicas String @db.VarChar(500)

  centroId Int
  centro   CENTRO @relation(fields: [centroId], references: [idCENTRO])
}

model PROGRAMA {
  idPROGRAMA  Int     @id @default(autoincrement())
  nivel       String  @db.VarChar(50)
  nombre      String  @db.VarChar(50)
  descripcion String  @db.Text
  activo      Boolean @default(true)

  recomendaciones     RECOMENDACION[]
  aprendices          APRENDIZ[]
  prediccionesDemanda PREDICCION_DEMANDA[]

  centroId Int
  centro   CENTRO @relation(fields: [centroId], references: [idCENTRO])

  programaId        Int?
  programa          PROGRAMA? @relation("ProgramaToPrograma", fields: [programaId], references: [idPROGRAMA])

  subProgramas      PROGRAMA[] @relation("ProgramaToPrograma")

  reporteId         Int?
  reporte           REPORTE? @relation("ReporteToPrograma", fields: [reporteId], references: [idREPORTE])
}

model RECOMENDACION {
  idRECOMENDACION Int    @id @default(autoincrement())
  nombre          String @db.VarChar(50)
  descripcion     String @db.VarChar(500)
  ranking         Int    @default(0)

  // ✅ CORRECCIÓN DE LÓGICA: el programa elegido pertenece a la RECOMENDACIÓN, no al REPORTE
  programaElegidoId Int?
  programaElegido   PROGRAMA? @relation(fields: [programaElegidoId], references: [idPROGRAMA])

  reporteId Int
  reporte   REPORTE @relation(fields: [reporteId], references: [idREPORTE])
}

model ASPIRANTE {
  idASPIRANTE     Int      @id
  nombre_completo String   @db.VarChar(50)
  fechaNacimiento DateTime @db.Date
  email           String   @db.VarChar(50)
  telefono        String   @db.VarChar(10)
  barrio          String   @db.VarChar(100)
  direccion       String   @db.VarChar(100)
  ocupacion       String
  institucion     String?
  activo          Boolean  @default(true)
  password        String
  foto            String?

  reportes       REPORTE[]
  respuestas_Asp RESPUESTAS_ASPIRANTE[]
}

model CODIGO_VERIFICACION {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(100)
  codigo    String   @db.VarChar(6)
  datos     Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model TEST {
  idTEST      Int    @id @default(autoincrement())
  nombre      String
  descripcion String @db.VarChar(500)

  reporte   REPORTE[]
  preguntas PREGUNTAS[]
}

model REPORTE {
  idREPORTE Int      @id @default(autoincrement())
  Fecha     DateTime @default(now())

  puntajeR Int @default(0)
  puntajeI Int @default(0)
  puntajeA Int @default(0)
  puntajeS Int @default(0)
  puntajeE Int @default(0)
  puntajeC Int @default(0)

  testId Int
  test   TEST @relation(fields: [testId], references: [idTEST])

  aspiranteId Int
  aspirante   ASPIRANTE @relation(fields: [aspiranteId], references: [idASPIRANTE])

  respuestas_Asp  RESPUESTAS_ASPIRANTE[]
  recomendaciones RECOMENDACION[]
  programas       PROGRAMA[] @relation("ReporteToPrograma")
}

model PREGUNTAS {
  idPREGUNTAS    Int     @id @default(autoincrement())
  descripcion    String  @db.VarChar(500)
  perfilesRIASEC String? @db.VarChar(50)
  generadaIA     Boolean @default(true)

  testId Int
  test   TEST @relation(fields: [testId], references: [idTEST])

  respuestas_Asp RESPUESTAS_ASPIRANTE[]
}

model RESPUESTAS_ASPIRANTE {
  idRESPUESTASASP Int @id @default(autoincrement())

  valor Int?
  texto String? @db.Text

  aspiranteId Int
  aspirante   ASPIRANTE @relation(fields: [aspiranteId], references: [idASPIRANTE])

  preguntaId Int
  pregunta   PREGUNTAS @relation(fields: [preguntaId], references: [idPREGUNTAS])

  reporteId Int
  reporte   REPORTE @relation(fields: [reporteId], references: [idREPORTE])
}

model APRENDIZ {
  idAPRENDIZ Int @id

  tipoDocumento String @db.VarChar(50)
  nombre        String @db.VarChar(100)
  apellidos     String @db.VarChar(100)

  estado String @default("en formacion") @db.VarChar(50)

  horas_inasistidas Int @default(0)

  fechaIngreso DateTime @default(now())
  programaId   Int
  programa     PROGRAMA @relation(fields: [programaId], references: [idPROGRAMA])

  predicciones PREDICCION_DESERCION[]
}

// MODELO PREDICCION_DESERCION (existía en código, ahora en schema)
model PREDICCION_DESERCION {
  idPREDICCION Int      @id @default(autoincrement())
  fecha        DateTime @default(now())
  riesgo       String   @db.VarChar(50)
  probabilidad Float?

  aprendizId Int
  aprendiz   APRENDIZ @relation(fields: [aprendizId], references: [idAPRENDIZ])
}

// PREDICCION_DEMANDA ENRIQUECIDA
model PREDICCION_DEMANDA {
  idPREDICCION        Int      @id @default(autoincrement())
  fecha               DateTime @default(now())
  demanda             Float
  tendencia           String   @db.VarChar(20)

  // Nuevos campos requeridos
  confianza_prediccion Float    @default(0)
  trimestre_objetivo   String   @db.VarChar(20)
  accion_sugerida      String   @db.VarChar(20)

  programaId Int
  programa   PROGRAMA @relation(fields: [programaId], references: [idPROGRAMA])
}